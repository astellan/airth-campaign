{
  "campaign": {
    "meta": {
      "name": "Airth Campaign",
      "system": "AD&D",
      "setting_genre": "Dark Fantasy Post-Apocalyptic",
      "current_date": "Year ~300 (The Rising period)",
      "current_year": 300
    },
    "calendar": {
      "name": "Calendar of Airth",
      "description": "A reconstructed calendar rooted in pre-Roman Iberian and Amazigh seasonal observances. Used across Velgroth-Lucernia, the Imazuran Confederation, and the contested wilds of the Luric March.",
      "structure": {
        "total_days": 365,
        "months_count": 12,
        "standard_month_days": 30,
        "long_month_days": 31,
        "long_month": "Voarn",
        "liminal_days": {
          "count": 4,
          "name": "Ardaneth",
          "description": "Days outside the months, observed when equilibrium breaks, boundaries thin, or seasonal veils part. Positioned at solstices and equinoxes."
        }
      },
      "lunar_cycle": {
        "days_per_cycle": 28,
        "uses": [
          "planting",
          "magic",
          "omen-reading"
        ]
      },
      "months": [
        {
          "index": 1,
          "name": "Karnon",
          "days": 30,
          "season": "Deep Winter",
          "meaning": "The enfolding dark; silence"
        },
        {
          "index": 2,
          "name": "Thunor",
          "days": 30,
          "season": "Late Winter",
          "meaning": "Storms and clearings"
        },
        {
          "index": 3,
          "name": "Arkun",
          "days": 30,
          "season": "Early Spring",
          "meaning": "Sprouts and greening"
        },
        {
          "index": 4,
          "name": "Nabaia",
          "days": 30,
          "season": "Spring",
          "meaning": "Fertility, rising waters"
        },
        {
          "index": 5,
          "name": "Ulkar",
          "days": 30,
          "season": "Late Spring",
          "meaning": "Warm rains and long days"
        },
        {
          "index": 6,
          "name": "Sarnath",
          "days": 30,
          "season": "Early Summer",
          "meaning": "Fire, heat, late night revels"
        },
        {
          "index": 7,
          "name": "Belghaen",
          "days": 30,
          "season": "Mid Summer",
          "meaning": "Haze, deep sun, ripening crops"
        },
        {
          "index": 8,
          "name": "Keltoi",
          "days": 30,
          "season": "Late Summer",
          "meaning": "Dry winds, dust"
        },
        {
          "index": 9,
          "name": "Ragaia",
          "days": 30,
          "season": "Harvest",
          "meaning": "Smoke, ash, grains"
        },
        {
          "index": 10,
          "name": "Dumnos",
          "days": 30,
          "season": "Autumn",
          "meaning": "Descent, decay"
        },
        {
          "index": 11,
          "name": "Eshmun",
          "days": 30,
          "season": "Emberfall",
          "meaning": "Dimming coals, still and cold nights"
        },
        {
          "index": 12,
          "name": "Voarn",
          "days": 31,
          "season": "Frostfall",
          "meaning": "Frost, veils, dimming light"
        }
      ],
      "ardaneth": [
        {
          "name": "Ibnuth",
          "placement": "Between Karnon & Thunor",
          "season_marker": "Midwinter (Winter Solstice)",
          "color": "Black",
          "title": "The Veil-Still",
          "observances": "A silent night of ancestral remembrance. Fires are ceremonially extinguished and re-lit."
        },
        {
          "name": "Raaneth",
          "placement": "Between Arkun & Nabaia",
          "season_marker": "Spring Equinox",
          "color": "Green",
          "title": "The Gate-Opening",
          "observances": "Threshold rites, seed offerings, and river blessings."
        },
        {
          "name": "Ulziran",
          "placement": "Between Sarnath & Belghaen",
          "season_marker": "Midsummer (Summer Solstice)",
          "color": "Gold",
          "title": "The High Eye",
          "observances": "Celebratory rites to elders, sun-rites, masked revels."
        },
        {
          "name": "Dazkur",
          "placement": "Between Dumnos & Eshmun",
          "season_marker": "Autumn Equinox",
          "color": "Red",
          "title": "The Hinge of Descent",
          "observances": "Harvest mourning, burning of effigies, youthful dalliance."
        }
      ],
      "feast_days": [
        {
          "name": "Taranuz",
          "deity": "Veltharos",
          "date": {
            "day": 11,
            "month": "Karnon"
          },
          "etymology": "From Taran- (Proto-Celtic for thunder) + -uz (veneration)",
          "observances": "Sky vigils, tower rites, silence before storm"
        },
        {
          "name": "Ambarra",
          "deity": "Bandua",
          "date": {
            "day": 6,
            "month": "Thunor"
          },
          "etymology": "From Iberian ambar ('enclosure,' 'dwelling')",
          "observances": "Hearth rites, oaths, home-ward blessings"
        },
        {
          "name": "Cossial",
          "deity": "Cossus",
          "date": {
            "day": 18,
            "month": "Ulkar"
          },
          "etymology": "From the god's own name + -ial (Lusitanian adjectival)",
          "observances": "Duels, war dances, endurance tests"
        },
        {
          "name": "Tilanda",
          "deity": "Ossamar",
          "date": {
            "day": 9,
            "month": "Nabaia"
          },
          "etymology": "From Amazigh till ('truth') + anda ('flow')",
          "observances": "River offerings, crossing rites"
        },
        {
          "name": "Thuldar",
          "deity": "Thulda",
          "date": {
            "day": 27,
            "month": "Dumnos"
          },
          "etymology": "From the goddess's name + -ar (old agentive ending)",
          "observances": "Wool veiling (coming of age for girls), funeral chants"
        },
        {
          "name": "Israya",
          "deity": "Isarna",
          "date": {
            "day": 7,
            "month": "Arkun"
          },
          "etymology": "From Isarna + raya (path or track in Mozarabic)",
          "observances": "Way-clearing, lantern processions"
        },
        {
          "name": "Lugazil",
          "deity": "Lugus",
          "date": {
            "day": 13,
            "month": "Keltoi"
          },
          "etymology": "From Lugus + azil (Berber root for 'refuge' or 'binding')",
          "observances": "Law-readings, feast of artisans"
        },
        {
          "name": "Malzun",
          "deity": "Malac",
          "date": {
            "day": 2,
            "month": "Belghaen"
          },
          "etymology": "From Amazigh mazun (possessed, touched by fire)",
          "observances": "Prophecy rites, flame trials"
        }
      ]
    },
